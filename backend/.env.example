# Corti API Credentials
# Get these from the Corti API Console: https://corti-api-console.web.app/
CORTI_CLIENT_ID=your-client-id-here
CORTI_CLIENT_SECRET=your-client-secret-here
CORTI_TENANT=your-tenant-name-here
CORTI_ENVIRONMENT=your-environment-here

# Corti base URLs (derived automatically from above)
# Auth URL: https://auth.{ENVIRONMENT}.corti.app/realms/{TENANT}/protocol/openid-connect/token
# API URL:  https://api.{ENVIRONMENT}.corti.app

# Server config
PORT=3001
FRONTEND_URL=http://localhost:5173
